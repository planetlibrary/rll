---
// src/pages/publications.astro
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications');
const sorted  = allPubs.sort((a,b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));

const byYear = sorted.reduce<Map<number, typeof sorted>>((acc, pub) => {
  const y = pub.data.year;
  if (!acc.has(y)) acc.set(y, []);
  acc.get(y)!.push(pub);
  return acc;
}, new Map());

const years = Array.from(byYear.entries());
---

<Layout title="Publications" description={`Representations Learning Lab — ${allPubs.length} papers.`}>

  <div class="mx-auto max-w-5xl px-5 pt-16 pb-10 sm:px-8 sm:pt-20">
    <p class="label mb-4">Research output</p>
    <h1 class="font-display text-3xl font-bold text-ink sm:text-4xl">Publications</h1>
    <p class="mt-3 text-sm text-ink-muted">
      Lab members in <strong class="font-semibold text-ink">bold</strong>.
      {allPubs.length} papers total.
    </p>
  </div>

  <div class="mx-auto max-w-5xl px-5 pb-24 sm:px-8">
    {years.map(([year, pubs]) => (
      <section class="mb-14" aria-labelledby={`year-${year}`}>
        <h2 id={`year-${year}`}
            class="sticky top-[57px] z-10 -mx-5 flex items-center gap-4 bg-surface/95 backdrop-blur-sm px-5 py-2 sm:-mx-8 sm:px-8">
          <span class="font-display text-sm font-bold text-ink tabular-nums">{year}</span>
          <span class="h-px flex-1 bg-surface-border" aria-hidden="true" />
          <span class="text-xs text-ink-faint">{pubs.length}</span>
        </h2>

        <div class="mt-1">
          {pubs.map(pub => <PublicationCard publication={pub} />)}
        </div>
      </section>
    ))}
  </div>
</Layout>
