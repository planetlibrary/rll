---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: '/',             label: 'Home' },
  { href: '/team',         label: 'Team' },
  { href: '/publications', label: 'Publications' },
  { href: '/research',     label: 'Research' },
];
---

<footer class="mt-24 border-t border-surface-border bg-surface-raised">
  <div class="mx-auto max-w-5xl px-5 py-10 sm:px-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">

      <span class="font-display text-sm font-bold tracking-widest uppercase text-ink">RLL</span>

      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-7 gap-y-1" role="list">
          {footerLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-ink-faint hover:text-ink transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="mt-8 border-t border-surface-border pt-6 text-xs text-ink-faint">
      <p>
        &copy; {currentYear} Representations Learning Lab, IAI, TCG CREST.
        Built with <a href="https://astro.build" class="hover:text-ink-muted transition-colors">Astro</a>
        &amp; <a href="https://tailwindcss.com" class="hover:text-ink-muted transition-colors">Tailwind CSS</a>.
      </p>
    </div>
  </div>
</footer>
