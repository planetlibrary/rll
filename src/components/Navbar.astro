---
// src/components/Navbar.astro
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/',             label: 'Home' },
  { href: '/team',         label: 'Team' },
  { href: '/publications', label: 'Publications' },
  { href: '/research',     label: 'Research' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-surface-border"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-8"
    aria-label="Main navigation"
  >
    <!-- Wordmark — clean text-only, no brackets, all caps like MIT/Stanford -->
    <a
      href="/"
      class="font-display text-sm font-bold tracking-widest uppercase text-ink hover:text-ink-muted transition-colors"
      aria-label="Representations Learning Lab — home"
    >
      RLL
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-6 md:flex" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm transition-colors duration-150',
              isActive(href)
                ? 'text-ink font-medium'
                : 'text-ink-muted hover:text-ink',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      type="button"
      class="flex items-center justify-center p-1.5 text-ink-muted hover:text-ink md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
    >
      <svg id="icon-open" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="icon-close" class="hidden h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-surface-border bg-surface md:hidden"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col px-5 py-3 gap-0.5" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2.5 text-sm transition-colors',
              isActive(href)
                ? 'text-ink font-medium'
                : 'text-ink-muted hover:text-ink',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle   = document.getElementById('menu-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });

  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
